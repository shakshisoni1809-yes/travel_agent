import json

###//DISPLAY THE MEMORY

with open("travel_memory.json", "r") as f:
    memory = json.load(f)

clean = []
for msg in memory:
    if msg["type"] == "human":
        clean.append({"User": msg["data"]["content"]})
    elif msg["type"] == "ai" and msg["data"]["content"]:
        clean.append({"Agent": msg["data"]["content"]})

print(json.dumps(clean, indent=2, ensure_ascii=False))
